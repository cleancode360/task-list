        |       |           |-- LogGateway.java
        |       |-- infrastructure/
        |           |-- gatewayadapter/
        |           |   |-- slf4j/
        |           |   |   |-- log/
        |           |   |       |-- SLF4JLogAdapter.java
        |           |   |-- rest/
        |           |       |-- RestClient.java
        |           |-- config/
        |           |   |-- SecurityConfig.java
